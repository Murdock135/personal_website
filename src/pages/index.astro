---
import Layout from '../layouts/Layout.astro';

const news = [
  { date: 'Apr 2025', text: 'Paper accepted at ACL 2025 — "Calibrating LLMs for Low-Resource NLP".' },
  { date: 'Jan 2025', text: 'Started PhD at [University Name] in the NLP & AI Lab.' },
  { date: 'Dec 2024', text: 'Presented workshop paper at EMNLP 2024.' },
  { date: 'Sep 2024', text: 'Received Graduate Research Fellowship.' },
  { date: 'Jun 2024', text: 'BS in Computer Science (Summa Cum Laude).' },
];

const social = [
  {
    name: 'GitHub',
    url: 'https://github.com/qzarifuislam',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>`,
  },
  {
    name: 'LinkedIn',
    url: 'https://linkedin.com/in/qzarifuislam',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
  {
    name: 'Google Scholar',
    url: 'https://scholar.google.com/citations?user=PLACEHOLDER',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z"/></svg>`,
  },
  {
    name: 'Email',
    url: 'mailto:qzarif@example.edu',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
  },
];
---

<Layout title="Home" description="Qazi Zarif Ul Islam — CS PhD student researching NLP, ML, and AI systems.">
  <div class="max-w-5xl mx-auto px-6 py-16">

    <!-- Hero Section -->
    <section class="flex flex-col md:flex-row items-center md:items-start gap-12 mb-24">
      <!-- Profile image with spotlight -->
      <div class="relative flex-shrink-0">
        <div
          class="w-64 h-64 overflow-hidden spotlight-img"
          style="border-radius: 30%;"
        >
          <img
            src="/profile.jpg"
            alt="Qazi Zarif Ul Islam"
            width="256"
            height="256"
            class="w-full h-full object-cover"
            onerror="this.src='https://ui-avatars.com/api/?name=QZ&background=1a1a1a&color=D4FF80&size=256'"
          />
        </div>
        <!-- Volt glow ring (dark mode only) -->
        <div
          class="absolute inset-0 pointer-events-none"
          style="border-radius: 30%; box-shadow: 0 0 0 2px rgba(212,255,128,0.25);"
        ></div>
      </div>

      <!-- Bio -->
      <div class="flex-1 text-center md:text-left">
        <h1 class="text-4xl font-bold tracking-tight mb-1" style="color: var(--color-text);">
          Qazi Zarif Ul Islam
        </h1>
        <p class="text-base font-medium mb-4" style="color: var(--color-accent);">
          PhD Student &middot; Computer Science
        </p>
        <p class="text-sm leading-relaxed mb-6 max-w-xl" style="color: var(--color-muted);">
          I am a first-year PhD student at <strong style="color: var(--color-text);">[University Name]</strong>,
          advised by <a href="#" class="underline underline-offset-2 transition-colors hover:opacity-80" style="color: var(--color-accent);">Prof. [Advisor Name]</a>.
          My research focuses on <strong style="color: var(--color-text);">natural language processing</strong>,
          <strong style="color: var(--color-text);">low-resource machine learning</strong>, and
          <strong style="color: var(--color-text);">AI alignment</strong>.
          I am broadly interested in making language models more reliable and accessible across languages and domains.
        </p>

        <!-- Social icons -->
        <div class="flex items-center gap-3 justify-center md:justify-start flex-wrap mb-6">
          {social.map(({ name, url, icon }) => (
            <a
              href={url}
              target={url.startsWith('mailto') ? undefined : '_blank'}
              rel="noopener noreferrer"
              aria-label={name}
              class="w-10 h-10 rounded-full flex items-center justify-center transition-all duration-200 hover:scale-110"
              style="background: var(--color-surface); border: 1px solid var(--color-border); color: var(--color-muted);"
              title={name}
            >
              <Fragment set:html={icon} />
            </a>
          ))}
        </div>

        <div class="flex gap-3 justify-center md:justify-start">
          <a href="/publications" class="btn-volt">View Publications</a>
          <a href="/cv" class="btn-ghost">Download CV</a>
        </div>
      </div>
    </section>

    <!-- News Timeline -->
    <section>
      <h2 class="section-title" style="color: var(--color-text);">
        <span style="color: var(--color-accent);">/</span> News
      </h2>
      <ol class="relative border-l ml-2" style="border-color: var(--color-border);">
        {news.map(({ date, text }) => (
          <li class="mb-8 ml-6">
            <span
              class="absolute -left-2 flex h-4 w-4 items-center justify-center rounded-full"
              style="background: var(--color-accent);"
            />
            <time class="mb-1 block text-xs font-semibold uppercase tracking-widest" style="color: var(--color-accent);">
              {date}
            </time>
            <p class="text-sm leading-relaxed" style="color: var(--color-muted);">{text}</p>
          </li>
        ))}
      </ol>
    </section>

  </div>
</Layout>
