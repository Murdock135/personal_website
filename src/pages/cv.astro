---
import Layout from '../layouts/Layout.astro';

const education = [
  {
    degree: 'PhD, Computer Science',
    institution: '[University Name]',
    period: '2025 – Present',
    details: 'Advisor: Prof. [Advisor Name] · Focus: NLP, AI Alignment',
  },
  {
    degree: 'BS, Computer Science',
    institution: '[Undergraduate University]',
    period: '2020 – 2024',
    details: 'Summa Cum Laude · GPA: 4.0/4.0',
  },
];

const awards = [
  { name: 'Graduate Research Fellowship', org: '[Funding Agency]', year: '2024' },
  { name: "Dean's List", org: '[Undergraduate University]', year: '2020–2024' },
];

const skills = {
  Languages: ['Python', 'Java', 'C++', 'SQL', 'Bash'],
  'ML/NLP Frameworks': ['PyTorch', 'HuggingFace Transformers', 'spaCy', 'NLTK', 'scikit-learn'],
  'Tools & Infra': ['Git', 'Docker', 'SLURM', 'Weights & Biases', 'LaTeX'],
};
---

<Layout title="CV" description="Curriculum Vitae of Qazi Zarif Ul Islam.">
  <div class="max-w-4xl mx-auto px-6 py-16">

    <!-- Header with download button -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6 mb-16">
      <div>
        <h1 class="text-3xl font-bold tracking-tight mb-1" style="color: var(--color-text);">
          Curriculum Vitae
        </h1>
        <p class="text-sm" style="color: var(--color-muted);">Qazi Zarif Ul Islam &middot; PhD Student, CS</p>
      </div>
      <a
        href="/cv.pdf"
        download
        class="btn-volt self-start sm:self-auto"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Download PDF
      </a>
    </div>

    <!-- Education -->
    <section class="mb-12">
      <h2 class="text-xl font-bold mb-6 pb-2 border-b" style="color: var(--color-text); border-color: var(--color-border);">
        Education
      </h2>
      <div class="flex flex-col gap-5">
        {education.map(({ degree, institution, period, details }) => (
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1">
            <div>
              <h3 class="font-semibold text-base" style="color: var(--color-text);">{degree}</h3>
              <p class="text-sm" style="color: var(--color-accent);">{institution}</p>
              <p class="text-sm" style="color: var(--color-muted);">{details}</p>
            </div>
            <time class="text-sm font-mono flex-shrink-0" style="color: var(--color-muted);">{period}</time>
          </div>
        ))}
      </div>
    </section>

    <!-- Publications summary -->
    <section class="mb-12">
      <h2 class="text-xl font-bold mb-6 pb-2 border-b" style="color: var(--color-text); border-color: var(--color-border);">
        Selected Publications
      </h2>
      <p class="text-sm mb-4" style="color: var(--color-muted);">
        See the full list on the <a href="/publications" class="underline underline-offset-2 hover:opacity-80" style="color: var(--color-accent);">Publications page</a>.
      </p>
      <ul class="flex flex-col gap-3 list-none">
        <li class="text-sm" style="color: var(--color-muted);">
          <strong style="color: var(--color-text);">Qazi Zarif Ul Islam</strong>, Jane Doe, John Smith.
          "Calibrating Large Language Models for Low-Resource NLP via Conformal Prediction."
          <em>ACL 2025.</em>
        </li>
        <li class="text-sm" style="color: var(--color-muted);">
          <strong style="color: var(--color-text);">Qazi Zarif Ul Islam</strong>, Alice Chen.
          "Few-Shot Named Entity Recognition in Code-Switched Text."
          <em>EMNLP Workshop, 2024.</em>
        </li>
      </ul>
    </section>

    <!-- Awards -->
    <section class="mb-12">
      <h2 class="text-xl font-bold mb-6 pb-2 border-b" style="color: var(--color-text); border-color: var(--color-border);">
        Honors & Awards
      </h2>
      <div class="flex flex-col gap-3">
        {awards.map(({ name, org, year }) => (
          <div class="flex items-start justify-between gap-2">
            <div>
              <p class="text-sm font-medium" style="color: var(--color-text);">{name}</p>
              <p class="text-xs" style="color: var(--color-muted);">{org}</p>
            </div>
            <span class="text-xs font-mono flex-shrink-0" style="color: var(--color-muted);">{year}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Skills -->
    <section class="mb-12">
      <h2 class="text-xl font-bold mb-6 pb-2 border-b" style="color: var(--color-text); border-color: var(--color-border);">
        Technical Skills
      </h2>
      <div class="flex flex-col gap-4">
        {Object.entries(skills).map(([category, items]) => (
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest mb-2" style="color: var(--color-accent);">
              {category}
            </p>
            <div class="flex flex-wrap gap-2">
              {items.map((skill) => (
                <span
                  class="text-xs px-3 py-1 rounded-full font-mono"
                  style="background: var(--color-surface); border: 1px solid var(--color-border); color: var(--color-text);"
                >
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

  </div>
</Layout>
