---
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t" style="border-color: var(--color-border);">
  <div class="max-w-5xl mx-auto px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm" style="color: var(--color-muted);">
    <p>&copy; {year} Qazi Zarif Ul Islam. All rights reserved.</p>
    <p>
      Built with{' '}
      <a
        href="https://astro.build"
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors duration-200 font-medium"
        style="color: var(--color-accent);"
      >
        Astro
      </a>{' '}
      &amp;{' '}
      <a
        href="https://tailwindcss.com"
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors duration-200 font-medium"
        style="color: var(--color-accent);"
      >
        Tailwind CSS
      </a>
    </p>
  </div>
</footer>
