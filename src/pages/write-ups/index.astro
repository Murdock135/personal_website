---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('write-ups', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<Layout title="Write-ups" description="Technical blog posts and write-ups by Qazi Zarif Ul Islam.">
  <div class="max-w-5xl mx-auto px-6 py-16">

    <h1 class="section-title" style="color: var(--color-text);">
      <span style="color: var(--color-accent);">/</span> Write-ups
    </h1>
    <p class="text-sm mb-10 max-w-2xl" style="color: var(--color-muted);">
      Technical notes, tutorials, and essays on machine learning, NLP research, and adjacent topics.
      Math rendered with KaTeX; code with Shiki.
    </p>

    {posts.length === 0 ? (
      <p class="text-sm" style="color: var(--color-muted);">No posts yet — check back soon!</p>
    ) : (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post) => (
          <a
            href={`/write-ups/${post.id}`}
            class="glass p-6 flex flex-col gap-3 transition-all duration-300 hover:scale-[1.02] hover:shadow-xl group no-underline"
          >
            {post.data.image && (
              <img
                src={post.data.image}
                alt={post.data.title}
                class="w-full h-36 object-cover rounded-xl mb-1"
              />
            )}
            <div class="flex flex-wrap gap-1.5">
              {post.data.tags.map((tag: string) => (
                <span
                  class="text-xs px-2 py-0.5 rounded-md font-mono"
                  style="background: var(--color-surface); border: 1px solid var(--color-border); color: var(--color-muted);"
                >
                  {tag}
                </span>
              ))}
            </div>
            <h2
              class="font-semibold text-base leading-snug transition-colors duration-200"
              style="color: var(--color-text);"
            >
              {post.data.title}
            </h2>
            <p class="text-sm leading-relaxed flex-1" style="color: var(--color-muted);">
              {post.data.description}
            </p>
            <time class="text-xs font-mono" style="color: var(--color-muted);">
              {formatDate(post.data.date)}
            </time>
          </a>
        ))}
      </div>
    )}
  </div>
</Layout>
